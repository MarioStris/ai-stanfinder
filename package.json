{
  "name": "ai-stanfinder",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm --filter @ai-stanfinder/api run build",
    "start": "node apps/api/dist/index.js",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "prisma generate --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "prisma": "6.19.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "@clerk/shared"
    ]
  }
}
