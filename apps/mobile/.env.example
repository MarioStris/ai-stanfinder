# AI StanFinder Mobile App - Environment Variables
# Copy this file to .env and fill in the values.

# ----- API Configuration -----
# Backend API URL (required)
# Development: http://localhost:3000
# Production:  https://api-production-6622.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3000

# ----- Authentication (Clerk) -----
# Clerk publishable key for auth (required)
# Get from: https://dashboard.clerk.com → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ----- EAS Build -----
# EAS project ID (set automatically by eas init)
EAS_PROJECT_ID=

# ----- Push Notifications (Expo) -----
# Expo push notification access token (optional, for sending push from server)
EXPO_ACCESS_TOKEN=

# ----- Feature Flags -----
# Enable debug mode (optional, default: false)
EXPO_PUBLIC_DEBUG_MODE=false

# ----- Sentry Error Tracking (optional) -----
# Sentry DSN for error reporting
EXPO_PUBLIC_SENTRY_DSN=
