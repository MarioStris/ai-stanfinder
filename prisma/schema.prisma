generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  GRACE_PERIOD
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
}

enum PropertySource {
  NJUSKALO
  INDEX_OGLASI
  CROZILLA
  NEPREMICNINE_SI
  HALOOGLASI_RS
}

enum NotificationType {
  NEW_MATCH
  DAILY_SUMMARY
  AI_SUGGESTION
  SYSTEM
}

enum NotificationChannel {
  PUSH
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// ============================================================
// USER
// ============================================================

model User {
  id          String    @id @default(cuid())
  clerkId     String    @unique @map("clerk_id")
  email       String    @unique
  locale      String    @default("hr")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  subscription Subscription?
  filters      Filter[]
  matches      Match[]
  notifications Notification[]
  pushTokens   PushToken[]
  apiUsage     ApiUsage[]
  preferences  UserPreference?

  @@map("users")
}

// ============================================================
// SUBSCRIPTION
// ============================================================

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique @map("user_id")
  tier               SubscriptionTier   @default(FREE)
  revenuecatId       String?            @map("revenuecat_id")
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelledAt        DateTime?          @map("cancelled_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================================
// FILTER
// ============================================================

model Filter {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  name         String        @default("Moj filter")
  city         String?
  propertyType PropertyType? @map("property_type")
  priceMin     Int?          @map("price_min")
  priceMax     Int?          @map("price_max")
  areaMin      Int?          @map("area_min")
  areaMax      Int?          @map("area_max")
  rooms        Int?
  freeText     String?       @map("free_text")
  isNewBuild   Boolean?      @map("is_new_build")
  isActive     Boolean       @default(true) @map("is_active")
  filterHash   String?       @map("filter_hash")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches Match[]

  @@index([userId, isActive])
  @@map("filters")
}

// ============================================================
// PROPERTY
// ============================================================

model Property {
  id            String         @id @default(cuid())
  externalId    String         @unique @map("external_id")
  source        PropertySource @default(NJUSKALO)
  sourceUrl     String?        @map("source_url")
  title         String
  description   String?        @db.Text
  propertyType  PropertyType   @map("property_type")
  city          String
  neighborhood  String?
  address       String?
  price         Int
  area          Int
  pricePerM2    Int?           @map("price_per_m2")
  rooms         Int?
  floor         Int?
  totalFloors   Int?           @map("total_floors")
  yearBuilt     Int?           @map("year_built")
  isNewBuild    Boolean        @default(false) @map("is_new_build")
  condition     String?
  hasParking    Boolean        @default(false) @map("has_parking")
  hasBalcony    Boolean        @default(false) @map("has_balcony")
  hasElevator   Boolean        @default(false) @map("has_elevator")
  images        String[]
  agentName     String?        @map("agent_name")
  agentPhone    String?        @map("agent_phone")
  agentEmail    String?        @map("agent_email")
  isActive      Boolean        @default(true) @map("is_active")
  firstSeenAt   DateTime       @default(now()) @map("first_seen_at")
  lastSeenAt    DateTime       @default(now()) @map("last_seen_at")
  deactivatedAt DateTime?      @map("deactivated_at")
  rawData       Json?          @map("raw_data")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  matches Match[]

  @@index([city, propertyType, isActive])
  @@index([price, area])
  @@index([source, externalId])
  @@index([isActive, lastSeenAt])
  @@map("properties")
}

// ============================================================
// MATCH
// ============================================================

model Match {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  filterId     String    @map("filter_id")
  propertyId   String    @map("property_id")
  matchPercent Int       @map("match_percent")
  aiComment    String?   @map("ai_comment") @db.Text
  rank         Int
  isNew        Boolean   @default(true) @map("is_new")
  isSeen       Boolean   @default(false) @map("is_seen")
  notifiedAt   DateTime? @map("notified_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filter   Filter   @relation(fields: [filterId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([filterId, propertyId])
  @@index([userId, filterId, createdAt(sort: Desc)])
  @@index([isNew, userId])
  @@map("matches")
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  channel   NotificationChannel @default(PUSH)
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?           @map("sent_at")
  readAt    DateTime?           @map("read_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, channel])
  @@map("notifications")
}

// ============================================================
// PUSH TOKEN
// ============================================================

model PushToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("push_tokens")
}

// ============================================================
// API USAGE
// ============================================================

model ApiUsage {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  endpoint     String
  tokensInput  Int      @map("tokens_input")
  tokensOutput Int      @map("tokens_output")
  costUsd      Decimal  @map("cost_usd") @db.Decimal(10, 6)
  durationMs   Int      @map("duration_ms")
  cacheHit     Boolean  @default(false) @map("cache_hit")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("api_usage")
}

// ============================================================
// USER PREFERENCE
// ============================================================

model UserPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique @map("user_id")
  pushEnabled           Boolean  @default(true) @map("push_enabled")
  emailEnabled          Boolean  @default(false) @map("email_enabled")
  notificationFrequency String   @default("instant") @map("notification_frequency")
  minMatchPercent       Int      @default(80) @map("min_match_percent")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
